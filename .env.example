# Copy to .env.local for local dev; paste same keys into Vercel → Project → Settings → Environment Variables (Production).
# Never commit real secrets.

# --- Supabase (required for cloud APIs + browser reads) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional alias used by some paths (can equal NEXT_PUBLIC_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=

# Storage bucket name (must match Supabase Storage; default in code: memory-fragments)
SUPABASE_STORAGE_BUCKET=
# Optional alternate name for the same bucket
# MEMORY_FRAGMENTS_BUCKET_NAME=

# Legacy: force cloud UI when public pair missing (normally leave unset)
# NEXT_PUBLIC_MEMORY_GALLERY_CLOUD=1

# --- Optional site / geocode ---
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
# NOMINATIM_CONTACT_EMAIL=you@example.com

# --- Optional caps ---
# NEXT_PUBLIC_MAX_GALLERY_ITEMS=200
