# Copy to .env.local for local dev; paste the same keys into Vercel → Project → Settings → Environment Variables.
# Never commit real secrets.

# =============================================================================
# Vercel / production parity (read this if “本地正常、线上异常”)
# =============================================================================
# 1) Vercel does NOT expand shell-style references. Do NOT use:
#      SUPABASE_ANON_KEY=${NEXT_PUBLIC_SUPABASE_ANON_KEY}
#    Paste the anon key twice as two separate plaintext variables if both are needed.
# 2) Add variables for Production AND Preview (and Development if you use Vercel dev URLs).
# 3) After changing env vars, trigger a new Production Deployment (Redeploy).
# 4) Browser bundle only sees NEXT_PUBLIC_* — set those on Vercel or client uploads / gallery cloud break.
# 5) Supabase: run `supabase/schema.sql` (or diff your DB). Memory Dump needs Storage INSERT for anon +
#    policy `memory_images_insert_public` on table `memory_images` (see schema comments).

# --- Supabase (server + browser) ---
# Server API routes (service role). URL can match the public project URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required in the client bundle (must be set on Vercel for deploy to match local).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server copy of anon (must be literal on Vercel, not ${...}).
SUPABASE_ANON_KEY=

# Storage bucket name (Dashboard → Storage). Server + client should use the SAME bucket name.
SUPABASE_STORAGE_BUCKET=
NEXT_PUBLIC_STORAGE_BUCKET=memory-fragments
# Optional alternate name for the same bucket
# MEMORY_FRAGMENTS_BUCKET_NAME=

# Production site URL (geocode Referer, absolute links). On Vercel you can omit if you rely on VERCEL_URL.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Legacy: force cloud UI when public pair missing (normally leave unset)
# NEXT_PUBLIC_MEMORY_GALLERY_CLOUD=1

# --- Optional site / geocode ---
# NOMINATIM_CONTACT_EMAIL=you@example.com

# --- Optional caps ---
# NEXT_PUBLIC_MAX_GALLERY_ITEMS=200
